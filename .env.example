# Copy to .env and fill in. The .env file is gitignored.

# Required: your Anthropic API key. The anthropic SDK reads this directly.
# (Alternatively, run `ant auth login` and leave this unset.)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides — these beat config.yaml. Prefix is OPEN_AGENCY_.
# OPEN_AGENCY_MODEL=claude-opus-4-8
# OPEN_AGENCY_EFFORT=high
# OPEN_AGENCY_COMPANY_NAME=Acme Inc
# OPEN_AGENCY_POLICY_PATH=/path/to/your_policy.md
